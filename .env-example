# Redis
REDIS_HOST=localhost:6379
PROCESSING_REQUEST_QUEUE=video_queue
PROCESSING_FINISHED_QUEUE=video_success_queue

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=videos
MINIO_USE_SSL=false

# HTTP
HTTP_PORT=8080

# Workers (padrão = número de núcleos da máquina)
# WORKER_COUNT=4

# Processamento
# MAX_FILE_SIZE_MB=5120

# Webhook (opcional: URL que recebe POST ao concluir cada job)
# WEBHOOK_SECRET=meu-segredo-hmac

# Observabilidade (opcional: endpoint OTLP para Jaeger/Tempo/etc.)
# OTEL_ENDPOINT=localhost:4318
# OTEL_SERVICE_NAME=video-processor
